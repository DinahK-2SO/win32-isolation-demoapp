<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Win32IsolationDemoApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Win32IsolationDemoApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="24">
            <StackPanel Spacing="12">
                <Button x:Name="PickFileButton" Click="PickFileButton_Click" Content="Pick TXT File and Read" />
                <TextBox x:Name="PickedFileContentBox"
                         Header="Selected File Content"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="160"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />

                <TextBox x:Name="PathInputBox"
                         Header="File Path"
                         PlaceholderText="Enter the full path to the file here" />
                <Button x:Name="ReadPathButton" Click="ReadPathButton_Click" Content="Read File by Path" />
                <TextBox x:Name="PathFileContentBox"
                         Header="Path File Content"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="160"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar: shows which file (full path) was read, and whether it succeeded or failed. Text is selectable/copyable. -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock x:Name="StatusBarText"
                       IsTextSelectionEnabled="True"
                       TextWrapping="Wrap"
                       Text="Ready" />
        </Border>
    </Grid>
</Page>
